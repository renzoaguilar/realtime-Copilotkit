OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Optional Langfuse Prompt Management.
# If these are missing or unavailable, the app uses local fallback prompts.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROMPT_LABEL=production
LANGFUSE_REALTIME_PROMPT_NAME=generic-realtime-system
LANGFUSE_TRANSCRIPTION_PROMPT_NAME=generic-realtime-transcription
